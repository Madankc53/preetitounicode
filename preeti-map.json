    "home_row": {
      "description": "A through ' keys",
      "keys": ["a", "A", "s", "S", "d", "D", "f", "F", "g", "G", "h", "H", "j", "J", "k", "K", "l", "L", ";", ":", "'", "\""]
    },
    "bottom_row": {
      "description": "Z through / keys",
      "keys": ["z", "Z", "x", "X", "c", "C", "v", "V", "b", "B", "n", "N", "m", "M", ",", "<", ".", ">", "/", "?"]
    },
    "space": {
      "keys": [" "]
    }
  },

