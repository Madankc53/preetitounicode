  "rules": [
    { "find": "cf]", "replace": "а§У" },
    { "find": "cfW", "replace": "а§Ф" },
    { "find": "cf", "replace": "а§Ж" },
    { "find": "O{", "replace": "а§И" },
    { "find": "pm", "replace": "а§К" },
    { "find": "P{", "replace": "а§Р" },
    { "find": "if", "replace": "а§Ј" },
    { "find": "em", "replace": "а§Э" },
    { "find": "f]", "replace": "а•Л" },
    { "find": "fW", "replace": "а•М" }
  ],
  "post_rules": [
    {
      "find": "а§њ([\\u0900-\\u097F])",
      "replace": "$1а§њ",
      "note": "Swaps Harswa I to follow the consonant"
    },
    {
      "find": "([\\u0900-\\u097F])\\{",
      "replace": "а§∞а•Н$1",
      "note": "Moves Reph to start of syllable"
    },
    {
      "find": "а§Ња•З",
      "replace": "а•Л",
      "note": "Joins split O matra"
    },
    {
      "find": "а§Ња•И",
      "replace": "а•М",
      "note": "Joins split AU matra"
    },
    {
      "find": "а§њ([\\u0900-\\u097F])а•Н([\\u0900-\\u097F])",
      "replace": "$1а•Н$2а§њ",
      "note": "Handles Harswa I with half letters"
