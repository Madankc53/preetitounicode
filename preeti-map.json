  },

  "notes": {
    "halanta_keys": ["` (backtick)", "d"],
    "halanta_note": "Both ` and d produce virama (U+094D). Used to suppress the inherent 'a' vowel in a consonant and form conjuncts (e.g. k+d+t = क्त).",
    "anusvara_keys": ["=", "\\", "z"],
    "visarga_keys":  ["_", "Z"],
    "chandrabindu_keys": ["~", "|"],
    "shift_note": "Many lowercase/uppercase pairs map to the same character (e.g. q/Q, w/W, e/E). Some uppercase keys produce different characters (e.g. r=ी, R=ृ).",
    "conjunct_formation": "Type consonant + d (virama) + consonant to form conjuncts. Example: k+d+n = क्न",
    "reph": "The 'reph' form of र is typed AFTER the consonant it sits above, then virama resolves it.",
    "devanagari_fullstop": "The period key (.) produces the Devanagari danda (।) U+0964, the standard Nepali sentence-ending mark.",
    "numerals": "Keys 0-9 produce Devanagari numerals ०-९ (U+0966–U+096F), not ASCII digits."
  },

  "javascript_usage": {
    "description": "Simple converter function for use in any JS project",
    "code": "function preetiToUnicode(preetiText) {\n  const map = { /* paste the 'map' object here */ };\n  return preetiText.split('').map(ch => map[ch]?.nepali ?? ch).join('');\n}"
  },

  "python_usage": {
    "description": "One-liner converter for Python",
    "code": "preeti_to_unicode = lambda text, m: ''.join(m.get(c, {}).get('nepali', c) for c in text)"
  }
}
