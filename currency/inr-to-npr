<script>
// Standard exchange rate: 1 Indian Rupee = 1.60 Nepalese Rupee
// (fixed under Nepal's currency peg to INR)
const RATE = 1.60;

function convertINRtoNPR() {
    let inrInput = document.getElementById('inr');
    let rawValue = inrInput.value;
    
    // Convert to number, default to 0 if empty or invalid
    let inrAmount = parseFloat(rawValue);
    if (isNaN(inrAmount)) {
        inrAmount = 0;
    }
    
    let nprAmount = inrAmount * RATE;
    let outputSpan = document.getElementById('output');
    outputSpan.innerHTML = nprAmount.toFixed(2) + ' NPR';
}

// Attach event listener to the INR input field
const inrField = document.getElementById('inr');
if (inrField) {
    inrField.addEventListener('input', convertINRtoNPR);
}

// Perform initial conversion on page load to display default value (1 INR)
convertINRtoNPR();
</script>

