    <script>
        const RATE = 1.60;

        function convertINRtoNPR() {
            let inrAmount = parseFloat(document.getElementById('inr').value) || 0;
            let nprAmount = inrAmount * RATE;
            document.getElementById('output').innerHTML = nprAmount.toFixed(2) + ' NPR';
        }

        // Populate conversion table
        function populateTable() {
            const amounts = [1, 10, 50, 100, 500, 1000, 5000, 10000];
            let html = '';
            amounts.forEach(amount => {
                html += `<tr>
                    <td>${amount} INR</td>
                    <td>${(amount * RATE).toFixed(2)} NPR</td>
                </tr>`;
            });
            document.getElementById('rate-table').innerHTML = html;
        }

        // Event listeners
        document.getElementById('inr').addEventListener('input', convertINRtoNPR);
        
        // Initialize
        window.onload = function() {
            convertINRtoNPR();
            populateTable();
        };
    </script>

